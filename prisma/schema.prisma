generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())

  products Product[]
  orders   Order[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  stock       Int
  createdAt   DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  orderItems OrderItem[]
}

model Order {
  id        Int      @id @default(autoincrement())
  total     Float
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  items OrderItem[]
}

model OrderItem {
  id       Int   @id @default(autoincrement())
  quantity Int
  price    Float

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  orderId Int
  order   Order @relation(fields: [orderId], references: [id])

  @@unique([orderId, productId])
}